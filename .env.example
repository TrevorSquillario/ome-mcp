# ome_mcp_v5 environment configuration
# Copy this file to .env and fill in values before starting.
# NEVER commit .env to version control.

# ── OME appliance ────────────────────────────────────────────────────────────
OME_IP=192.168.1.145
OME_PORT=443

# ── Credentials (required) ───────────────────────────────────────────────────
OME_USER=admin
OME_PASSWORD=CHANGEME

# ── TLS verification ─────────────────────────────────────────────────────────
# Set to "false" for self-signed certs in a lab environment.
# Set to "true" (or the path to a CA bundle) in production.
OME_VERIFY_SSL=false

# ── MCP Server listen port ───────────────────────────────────────────────────
OME_MCP_PORT=8000
OME_APP_ENV=dev